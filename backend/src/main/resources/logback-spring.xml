<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <include resource="org/springframework/boot/logging/logback/defaults.xml"/>

    <!-- Log directory — override via LOG_PATH env var in production -->
    <property name="LOG_PATH"          value="${LOG_PATH:-./logs}"/>
    <property name="SECURITY_LOG_FILE" value="${LOG_PATH}/security-audit.log"/>
    <property name="APP_LOG_FILE"      value="${LOG_PATH}/application.log"/>

    <!-- ============================================================
         Console appender (dev-friendly coloured output)
         ============================================================ -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>${CONSOLE_LOG_PATTERN}</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <!-- ============================================================
         Security audit file (rolling by day + size)
         ============================================================ -->
    <appender name="SECURITY_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${SECURITY_LOG_FILE}</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <!-- daily roll; compress old logs -->
            <fileNamePattern>${LOG_PATH}/security-audit.%d{yyyy-MM-dd}.%i.log.gz</fileNamePattern>
            <maxFileSize>10MB</maxFileSize>
            <maxHistory>90</maxHistory>   <!-- retain 90 days for compliance -->
            <totalSizeCap>2GB</totalSizeCap>
        </rollingPolicy>
        <encoder>
            <!-- Structured single-line format: easy to ingest into ELK / Splunk -->
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <!--
        Async wrapper for SECURITY_FILE.
        - discardingThreshold=0  : never discard security events when queue is full
        - queueSize=512          : buffers bursts without blocking the caller thread
        - includeCallerData=false: skip expensive stack trace extraction (performance)
    -->
    <appender name="ASYNC_SECURITY_FILE" class="ch.qos.logback.classic.AsyncAppender">
        <discardingThreshold>0</discardingThreshold>
        <queueSize>512</queueSize>
        <includeCallerData>false</includeCallerData>
        <neverBlock>false</neverBlock>
        <appender-ref ref="SECURITY_FILE"/>
    </appender>

    <!-- ============================================================
         Application log file (rolling)
         ============================================================ -->
    <appender name="APP_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${APP_LOG_FILE}</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>${LOG_PATH}/application.%d{yyyy-MM-dd}.%i.log.gz</fileNamePattern>
            <maxFileSize>50MB</maxFileSize>
            <maxHistory>30</maxHistory>
            <totalSizeCap>1GB</totalSizeCap>
        </rollingPolicy>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <appender name="ASYNC_APP_FILE" class="ch.qos.logback.classic.AsyncAppender">
        <discardingThreshold>20</discardingThreshold>
        <queueSize>256</queueSize>
        <includeCallerData>false</includeCallerData>
        <appender-ref ref="APP_FILE"/>
    </appender>

    <!-- ============================================================
         Named logger: SECURITY_AUDIT
         Routes to dedicated security file + console (additivity=false
         prevents double-logging to root logger's appenders).
         ============================================================ -->
    <logger name="SECURITY_AUDIT" level="INFO" additivity="false">
        <appender-ref ref="ASYNC_SECURITY_FILE"/>
        <appender-ref ref="CONSOLE"/>
    </logger>

    <!-- Application package — INFO by default -->
    <logger name="com.hrkms" level="INFO"/>

    <!-- ============================================================
         Root logger — captures everything else
         ============================================================ -->
    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="ASYNC_APP_FILE"/>
    </root>

</configuration>
